<!DOCTYPE html>
<html lang="bg">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>RS Motors — Автокомплекс в София</title>
<meta name="description" content="RS Motors — автосервиз и автокозметичен център. София, България. Инженерна прецизност за изключителни машини." />

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Antonio:wght@300;400;500;600;700&family=Fraunces:ital,wght@0,300;0,400;0,500;1,300;1,400&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet" />

<style>
/* =========================================================
   RS MOTORS — Editorial Motorsport Aesthetic
   Deep carbon blacks · Surgical red accents · Industrial type
   ========================================================= */

:root {
  --ink:        #0a0a0c;
  --ink-soft:   #111114;
  --ink-card:   #16161a;
  --ink-line:   #1f1f25;
  --smoke:      #2a2a30;
  --steel:      #8c8c95;
  --chrome:     #d4d4d8;
  --bone:       #f4f1ea;
  --red:        #c8102e;
  --red-deep:   #8a0a1f;
  --red-glow:   rgba(200, 16, 46, 0.35);

  --font-display: 'Antonio', 'Impact', sans-serif;
  --font-serif:   'Fraunces', 'Times New Roman', serif;
  --font-mono:    'JetBrains Mono', 'Courier New', monospace;

  --gutter: clamp(1.25rem, 4vw, 3rem);
  --section-pad: clamp(5rem, 10vw, 9rem);
}

* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }

body {
  background: var(--ink);
  color: var(--bone);
  font-family: var(--font-serif);
  font-weight: 300;
  line-height: 1.6;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

img { max-width: 100%; display: block; }

/* Hide elements based on language */
html[lang="bg"] [data-lang="en"],
html[lang="en"] [data-lang="bg"] {
  display: none !important;
}

/* === FILM-GRAIN + NOISE OVERLAY === */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  opacity: 0.035;
  mix-blend-mode: overlay;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
}

/* =========== NAVIGATION =========== */
.nav {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.1rem var(--gutter);
  background: linear-gradient(to bottom, rgba(10,10,12,0.88), rgba(10,10,12,0));
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  transition: background 0.4s ease, padding 0.4s ease, border-color 0.4s ease;
  border-bottom: 1px solid transparent;
}
.nav.scrolled {
  background: rgba(10,10,12,0.94);
  border-bottom-color: var(--ink-line);
  padding: 0.75rem var(--gutter);
}

.brand {
  display: flex;
  align-items: center;
  gap: 0.9rem;
  text-decoration: none;
  color: var(--bone);
}
.brand-mark {
  width: 54px; height: 54px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  transition: width 0.4s, height 0.4s;
}
.nav.scrolled .brand-mark { width: 46px; height: 46px; }
.brand-mark img {
  width: 100%; height: 100%;
  object-fit: contain;
  filter: drop-shadow(0 0 8px rgba(200,16,46,0.25));
}

.brand-text {
  font-family: var(--font-display);
  font-weight: 600;
  font-size: 1.15rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  line-height: 1;
}
.brand-text em {
  font-style: normal;
  color: var(--red);
}
.brand-text small {
  display: block;
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.15em;
  color: var(--steel);
  font-weight: 400;
  margin-top: 0.3rem;
  text-transform: uppercase;
}

.nav-links {
  display: flex;
  gap: 2rem;
  list-style: none;
}
.nav-links a {
  font-family: var(--font-display);
  font-size: 0.78rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--chrome);
  text-decoration: none;
  transition: color 0.25s ease;
  position: relative;
}
.nav-links a:hover { color: var(--bone); }
.nav-links a::after {
  content: '';
  position: absolute;
  left: 0; bottom: -6px;
  width: 0; height: 1px;
  background: var(--red);
  transition: width 0.3s ease;
}
.nav-links a:hover::after { width: 100%; }

.nav-cta {
  font-family: var(--font-display);
  font-size: 0.78rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  padding: 0.7rem 1.3rem;
  background: var(--red);
  color: var(--bone);
  text-decoration: none;
  border: 1px solid var(--red);
  transition: all 0.3s ease;
  white-space: nowrap;
}
.nav-cta:hover {
  background: transparent;
  color: var(--red);
  box-shadow: 0 0 24px var(--red-glow);
}

/* Language toggle — sliding pill */
.lang-toggle {
  display: flex;
  align-items: center;
  background: var(--ink-line);
  border: 1px solid var(--smoke);
  border-radius: 50px;
  padding: 3px;
  position: relative;
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.1em;
  cursor: pointer;
  user-select: none;
  overflow: hidden;
}
.lang-toggle button {
  background: transparent;
  border: none;
  color: var(--steel);
  padding: 0.35rem 0.75rem;
  cursor: pointer;
  font-family: inherit;
  font-size: inherit;
  letter-spacing: inherit;
  font-weight: 500;
  transition: color 0.35s ease;
  position: relative;
  z-index: 2;
}
.lang-toggle button.active { color: var(--bone); }
.lang-toggle .pill {
  position: absolute;
  top: 3px; bottom: 3px;
  background: var(--red);
  border-radius: 50px;
  transition: all 0.35s cubic-bezier(.7,.1,.3,1);
  z-index: 1;
}

.nav-right { display: flex; align-items: center; gap: 1rem; }

.nav-toggle {
  display: none;
  width: 32px; height: 32px;
  background: transparent;
  border: none;
  cursor: pointer;
  flex-direction: column;
  justify-content: center;
  gap: 5px;
}
.nav-toggle span {
  display: block;
  width: 24px; height: 1.5px;
  background: var(--bone);
  transition: all 0.3s ease;
}

/* =========== HERO =========== */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: var(--gutter);
  padding-bottom: clamp(4rem, 8vw, 6rem);
  padding-top: 9rem;
  overflow: hidden;
  background:
    radial-gradient(ellipse at 75% 35%, rgba(200,16,46,0.13), transparent 55%),
    linear-gradient(180deg, #0a0a0c 0%, #050505 100%);
}

.hero-ghost {
  position: absolute;
  top: 8%;
  right: -4%;
  font-family: var(--font-display);
  font-weight: 700;
  font-size: clamp(18rem, 42vw, 46rem);
  line-height: 0.85;
  color: transparent;
  -webkit-text-stroke: 1px rgba(255,255,255,0.04);
  letter-spacing: -0.05em;
  pointer-events: none;
  user-select: none;
  z-index: 1;
}

.hero-ticker {
  position: absolute;
  top: 50%;
  left: 0; right: 0;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--red) 50%, transparent);
  opacity: 0.3;
  z-index: 2;
}

.hero-inner {
  position: relative;
  z-index: 5;
  max-width: 1500px;
  width: 100%;
  margin: 0 auto;
}

.hero-meta {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 2.5rem;
  font-family: var(--font-mono);
  font-size: 0.72rem;
  letter-spacing: 0.1em;
  color: var(--steel);
  text-transform: uppercase;
  flex-wrap: wrap;
  gap: 1rem;
}

.hero-meta .tag { display: flex; align-items: center; gap: 0.5rem; }
.hero-meta .dot {
  width: 6px; height: 6px;
  background: var(--red);
  border-radius: 50%;
  animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; box-shadow: 0 0 0 0 var(--red-glow); }
  50% { opacity: 0.6; box-shadow: 0 0 0 8px rgba(200,16,46,0); }
}

.hero-headline {
  font-family: var(--font-display);
  font-weight: 400;
  font-size: clamp(3rem, 10vw, 9.5rem);
  line-height: 0.92;
  letter-spacing: -0.02em;
  text-transform: uppercase;
  margin-bottom: 2rem;
  color: var(--bone);
}
.hero-headline .serif {
  font-family: var(--font-serif);
  font-style: italic;
  font-weight: 300;
  text-transform: none;
  letter-spacing: -0.01em;
  color: var(--chrome);
  display: block;
  font-size: 0.42em;
  margin-top: 0.4em;
  line-height: 1.2;
}
.hero-headline .red { color: var(--red); }
.hero-headline .stroke {
  color: transparent;
  -webkit-text-stroke: 1.5px var(--bone);
}

.hero-sub {
  max-width: 600px;
  font-size: 1.05rem;
  color: var(--chrome);
  margin-bottom: 3rem;
  font-family: var(--font-serif);
  font-style: italic;
  line-height: 1.5;
}

.hero-actions {
  display: flex;
  gap: 1.25rem;
  flex-wrap: wrap;
  align-items: center;
  margin-bottom: 3rem;
}

.btn-primary {
  font-family: var(--font-display);
  font-size: 0.85rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  padding: 1.1rem 2rem;
  background: var(--red);
  color: var(--bone);
  border: none;
  cursor: pointer;
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 0.8rem;
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}
.btn-primary::before {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--bone);
  transform: translateX(-101%);
  transition: transform 0.4s cubic-bezier(.7,.1,.3,1);
  z-index: 0;
}
.btn-primary:hover::before { transform: translateX(0); }
.btn-primary span, .btn-primary svg { position: relative; z-index: 1; transition: color 0.3s; }
.btn-primary:hover span, .btn-primary:hover svg { color: var(--ink); fill: var(--ink); }

.btn-ghost {
  font-family: var(--font-display);
  font-size: 0.85rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  padding: 1.1rem 2rem;
  background: transparent;
  color: var(--bone);
  border: 1px solid var(--smoke);
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  gap: 0.8rem;
  transition: all 0.3s ease;
}
.btn-ghost:hover {
  border-color: var(--bone);
  background: rgba(255,255,255,0.04);
}

.hero-stats {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: var(--ink-line);
  border-top: 1px solid var(--ink-line);
  border-bottom: 1px solid var(--ink-line);
}
.hero-stat {
  background: var(--ink);
  padding: 1.5rem 1.25rem;
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
}
.hero-stat .label {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.18em;
  color: var(--steel);
  text-transform: uppercase;
}
.hero-stat .value {
  font-family: var(--font-display);
  font-size: clamp(1.6rem, 3vw, 2.4rem);
  font-weight: 500;
  color: var(--bone);
  letter-spacing: -0.01em;
}
.hero-stat .value em {
  font-style: normal;
  color: var(--red);
}

/* =========== SECTION DEFAULTS =========== */
section {
  position: relative;
  z-index: 5;
  padding: var(--section-pad) var(--gutter);
}

.container {
  max-width: 1500px;
  margin: 0 auto;
}

.section-label {
  display: flex;
  align-items: center;
  gap: 1rem;
  font-family: var(--font-mono);
  font-size: 0.72rem;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--red);
  margin-bottom: 1.5rem;
}
.section-label::before {
  content: '';
  width: 40px; height: 1px;
  background: var(--red);
}

.section-title {
  font-family: var(--font-display);
  font-weight: 500;
  font-size: clamp(2.2rem, 5.5vw, 4.6rem);
  line-height: 0.98;
  letter-spacing: -0.02em;
  text-transform: uppercase;
  margin-bottom: 1.5rem;
  color: var(--bone);
}
.section-title .serif {
  font-family: var(--font-serif);
  font-style: italic;
  font-weight: 300;
  text-transform: none;
  color: var(--steel);
  letter-spacing: -0.01em;
}

/* =========== ABOUT =========== */
.about {
  background: var(--ink);
  border-top: 1px solid var(--ink-line);
}
.about-grid {
  display: grid;
  grid-template-columns: 1fr 1.1fr;
  gap: clamp(2rem, 6vw, 5rem);
  align-items: center;
}
.about-text p {
  font-size: 1.08rem;
  line-height: 1.7;
  margin-bottom: 1.25rem;
  color: var(--chrome);
  max-width: 54ch;
}
.about-text p.lead {
  font-size: 1.35rem;
  font-style: italic;
  color: var(--bone);
  line-height: 1.5;
  font-weight: 300;
  border-left: 2px solid var(--red);
  padding-left: 1.25rem;
  margin-bottom: 2rem;
}

/* Featured embossed logo */
.about-visual {
  position: relative;
  aspect-ratio: 1/1;
  background: var(--ink-soft);
  overflow: hidden;
  border: 1px solid var(--ink-line);
  box-shadow:
    0 30px 60px rgba(0,0,0,0.5),
    0 0 80px rgba(200,16,46,0.08);
}
.about-visual img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.about-visual::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, transparent 55%, rgba(10,10,12,0.4) 100%);
  pointer-events: none;
}

.about-visual .visual-label {
  position: absolute;
  bottom: 1.5rem; left: 1.5rem;
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.15em;
  color: var(--chrome);
  text-transform: uppercase;
  background: rgba(10,10,12,0.75);
  padding: 0.5rem 0.8rem;
  backdrop-filter: blur(8px);
  z-index: 2;
}
.about-visual .visual-number {
  position: absolute;
  top: 1.5rem; right: 1.5rem;
  font-family: var(--font-display);
  font-size: 2rem;
  color: var(--red);
  letter-spacing: 0.05em;
  z-index: 2;
  text-shadow: 0 2px 8px rgba(0,0,0,0.6);
}

/* =========== SERVICES =========== */
.services {
  background: linear-gradient(180deg, var(--ink) 0%, var(--ink-soft) 100%);
  border-top: 1px solid var(--ink-line);
}
.services-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  flex-wrap: wrap;
  gap: 2rem;
  margin-bottom: 4rem;
}
.services-intro {
  max-width: 480px;
  font-size: 1rem;
  color: var(--steel);
  font-style: italic;
  line-height: 1.6;
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1px;
  background: var(--ink-line);
  border: 1px solid var(--ink-line);
}

.service-card {
  background: var(--ink-card);
  padding: 2.25rem 2rem;
  min-height: 280px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  transition: background 0.4s ease;
  position: relative;
  overflow: hidden;
  cursor: default;
}
.service-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 0; height: 2px;
  background: var(--red);
  transition: width 0.5s cubic-bezier(.7,.1,.3,1);
}
.service-card:hover { background: var(--ink-line); }
.service-card:hover::before { width: 100%; }

.service-num {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--steel);
  letter-spacing: 0.15em;
  margin-bottom: 1.5rem;
}

.service-icon {
  width: 44px; height: 44px;
  margin-bottom: 1.5rem;
  color: var(--red);
}
.service-icon svg { width: 100%; height: 100%; }

.service-name {
  font-family: var(--font-display);
  font-size: 1.2rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.02em;
  margin-bottom: 0.75rem;
  color: var(--bone);
}
.service-desc {
  font-size: 0.9rem;
  color: var(--steel);
  line-height: 1.55;
}

.service-arrow {
  position: absolute;
  bottom: 1.5rem; right: 1.5rem;
  width: 22px; height: 22px;
  color: var(--smoke);
  transition: color 0.3s, transform 0.3s;
}
.service-card:hover .service-arrow {
  color: var(--red);
  transform: translate(4px, -4px);
}

/* =========== COSMETIC CENTER =========== */
.cosmetic {
  background: var(--ink-soft);
  border-top: 1px solid var(--ink-line);
  padding: 0;
}
.cosmetic-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 90vh;
}
.cosmetic-visual {
  position: relative;
  background:
    radial-gradient(ellipse at 40% 50%, rgba(200,16,46,0.15), transparent 60%),
    linear-gradient(135deg, #0f0f12 0%, #050505 100%);
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cosmetic-visual::before {
  content: '';
  position: absolute;
  inset: 0;
  background-image:
    radial-gradient(circle at 20% 30%, rgba(255,255,255,0.05) 0%, transparent 30%),
    radial-gradient(circle at 70% 70%, rgba(200,16,46,0.08) 0%, transparent 35%);
  animation: drift 12s ease-in-out infinite;
}
@keyframes drift {
  0%, 100% { transform: translate(0, 0); }
  50% { transform: translate(20px, -15px); }
}

.cosmetic-big {
  position: relative;
  z-index: 2;
  font-family: var(--font-display);
  font-weight: 700;
  font-size: clamp(4.5rem, 12vw, 12rem);
  line-height: 0.85;
  text-align: center;
  color: transparent;
  -webkit-text-stroke: 1.5px var(--bone);
  letter-spacing: -0.03em;
  padding: 2rem;
}
.cosmetic-big .fill {
  -webkit-text-stroke: 0;
  color: var(--red);
  display: block;
  font-style: italic;
  font-family: var(--font-serif);
  font-weight: 400;
  font-size: 0.3em;
  text-transform: none;
  letter-spacing: 0;
  margin-top: 0.5rem;
}

.cosmetic-content {
  padding: clamp(3rem, 7vw, 6rem) clamp(2rem, 5vw, 4rem);
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.cosmetic-intro {
  color: var(--chrome);
  font-size: 1.05rem;
  line-height: 1.6;
  margin-top: 1rem;
  max-width: 48ch;
}

.tier-list {
  margin-top: 2.5rem;
  display: flex;
  flex-direction: column;
}

.tier {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 1.25rem;
  align-items: center;
  padding: 1.4rem 0;
  border-bottom: 1px solid var(--ink-line);
  transition: padding 0.3s ease;
  cursor: default;
}
.tier:hover { padding-left: 1rem; }
.tier:last-child { border-bottom: none; }

.tier-num {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--steel);
  letter-spacing: 0.1em;
}
.tier-name {
  font-family: var(--font-display);
  font-size: 1.25rem;
  font-weight: 500;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: var(--bone);
}
.tier-name .accent { color: var(--red); }
.tier-mark {
  font-family: var(--font-serif);
  font-style: italic;
  color: var(--steel);
  font-size: 0.9rem;
}

.partner-note {
  margin-top: 3rem;
  padding: 1.5rem;
  border: 1px solid var(--ink-line);
  background: rgba(0,0,0,0.25);
}
.partner-note .partner-label {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  color: var(--red);
  letter-spacing: 0.2em;
  text-transform: uppercase;
  margin-bottom: 0.5rem;
}
.partner-note .partner-name {
  font-family: var(--font-display);
  font-size: 1.5rem;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  margin-bottom: 0.5rem;
}
.partner-note p {
  font-size: 0.92rem;
  color: var(--steel);
  line-height: 1.5;
}

/* =========== PRICING BOARD =========== */
.pricing {
  background: var(--ink);
  border-top: 1px solid var(--ink-line);
}

